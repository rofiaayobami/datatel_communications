# DATATEL COMMUNICATIONS PIPELINE — ENVIRONMENT CONFIGURATION TEMPLATE
# Instructions: Copy this file to '.env' and populate with your local values.

#  On-Premises PostgreSQL Configuration (Windows Host / pgAdmin)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=datatel_com
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_local_postgres_password_here

#  Docker / Airflow Core Environment Settings
AIRFLOW_IMAGE_NAME=apache/airflow:2.10.5
AIRFLOW_UID=50000

#  Host Local File System Directories (Paths outside Docker container)
# Note: Use forward slashes (/) for Windows absolute path layouts
CSV_DIR=C:/Users/YOUR_WINDOWS_USER/Documents/ALTSCHOOL_PROJECTS/telecom_pipeline project/data

#  Google Cloud Platform / BigQuery Warehouse Variables
GCP_PROJECT_ID=your-gcp-project-id-here
GCP_BIGQUERY_DATASET=datatel_warehouse_analytics
GCP_GCS_STAGING_BUCKET=your-gcs-staging-bucket-name
